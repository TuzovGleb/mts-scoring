# Скопируй в .env и впиши ключи. Без ключа провайдер работает в МОК-режиме
# (возвращает заглушку), чтобы можно было тестировать рассылку end-to-end.

PORT=8787
# CORS: домен фронта (через запятую). * — разрешить всё (только для локалки).
ALLOWED_ORIGINS=*

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- OpenAI (ChatGPT) ---
OPENAI_API_KEY=
# Модель с веб-поиском (Responses API, tool web_search). Уточни актуальный id.
OPENAI_MODEL=gpt-5.1

# --- Perplexity ("параллельс") ---
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar-deep-research

# --- Google Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
