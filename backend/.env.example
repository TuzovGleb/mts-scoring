# Скопируй в .env и впиши ключи. Без ключа провайдер работает в МОК-режиме
# (возвращает заглушку), чтобы можно было тестировать рассылку end-to-end.

PORT=8787
# CORS: домен фронта (через запятую). * — разрешить всё (только для локалки).
# Для прода укажи: https://tuzovgleb.github.io
ALLOWED_ORIGINS=*

# === ПОДКЛЮЧАЕМ СЕЙЧАС ===

# --- Parallel.ai (deep research) ---
# Ключ: https://platform.parallel.ai → API Keys
PARALLEL_API_KEY=
# Процессор глубины: pro | ultra (ultra = глубже/дольше) · *-fast быстрее
PARALLEL_PROCESSOR=ultra

# --- OpenAI (ChatGPT, Responses API + web_search) ---
# Ключ: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.1

# === ОПЦИОНАЛЬНО (можно добавить позже) ===

# --- Google Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Perplexity (Sonar) ---
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar-deep-research
